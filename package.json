{
  "name": "agenthub",
  "version": "2.1.0",
  "description": "AgentHub - 多 Agent 协同桌面工作台",
  "main": "out/main/index.js",
  "author": {
    "name": "AgentHub Team",
    "email": "team@agenthub.dev"
  },
  "license": "MIT",
  "engines": {
    "node": ">=24",
    "npm": ">=11"
  },
  "bin": {
    "agenthub-cli": "scripts/agenthub-cli.mjs"
  },
  "scripts": {
    "dev": "electron-vite dev --watch",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "build:win": "npm run build && electron-builder --win --publish never",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "cli": "node scripts/agenthub-cli.mjs",
    "build:mac": "npm run build && electron-builder --mac --publish never",
    "build:linux": "npm run build && electron-builder --linux --publish never",
    "build:all": "npm run build && electron-builder -mw --publish never",
    "unpack": "electron-builder --dir"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "electron-updater": "^6.6.2",
    "immer": "^11.1.8",
    "node-pty": "^1.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.18.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^24",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.5.12",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^4.1.7",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "happy-dom": "^20.10.6",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.18.0",
    "vite": "^7.3.6",
    "vitest": "^4.1.7"
  },
  "build": {
    "appId": "dev.agenthub.desktop",
    "productName": "AgentHub",
    "copyright": "Copyright (c) 2026 AgentHubTeam",
    "buildVersion": "2.1.0",
    "npmRebuild": false,
    "buildDependenciesFromSource": false,
    "files": [
      "out/**/*",
      "package.json",
      "!**/node_modules/*/{CHANGELOG.md,README.md,readme.md,*.d.ts,*.map,test/**,__tests__/**,*.test.*,*.spec.*}",
      "!**/node_modules/.bin",
      "!**/*.{md,markdown}",
      "!**/node_modules/*/{.bin,.cache,build,docs,example,examples,test,tests,__tests__,coverage,*.d.ts.map,*.d.ts}"
    ],
    "extraResources": [
      {
        "from": "build/installerSidebar.bmp",
        "to": "build/installerSidebar.bmp"
      },
      {
        "from": "LICENSE",
        "to": "LICENSE"
      }
    ],
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "protocols": [
      {
        "name": "AgentHub Protocol",
        "schemes": [
          "agenthub"
        ]
      }
    ],
    "fileAssociations": [
      {
        "ext": "agenthub-chat",
        "name": "AgentHub Chat Export",
        "role": "Editor"
      },
      {
        "ext": [
          "ts",
          "tsx",
          "js",
          "jsx",
          "py",
          "rs",
          "go",
          "java",
          "cpp",
          "c",
          "h",
          "hpp",
          "md",
          "json",
          "yaml",
          "yml",
          "toml"
        ],
        "name": "Code File",
        "role": "Editor"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "verifyUpdateCodeSignature": false,
      "signAndEditExecutable": false,
      "requestedExecutionLevel": "asInvoker",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": false,
      "shortcutName": "AgentHub",
      "artifactName": "${productName}-Setup-${version}.${ext}",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeader": "build/installerSidebar.bmp",
      "installerSidebar": "build/installerSidebar.bmp",
      "include": "build/installer.nsh",
      "displayLanguageSelector": false
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.png",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "darkModeSupport": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "extendInfo": {
        "NSHumanReadableCopyright": "Copyright (c) 2026 AgentHubTeam. All rights reserved.",
        "CFBundleURLSchemes": [
          "agenthub"
        ],
        "LSApplicationCategoryType": "public.app-category.developer-tools",
        "LSEnvironment": {
          "AGENTHUB_VERSION": "${version}"
        }
      },
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon-linux.png",
      "category": "Development",
      "vendor": "AgentHubTeam",
      "maintainer": "AgentHubTeam <team@agenthub.dev>",
      "description": "AgentHub - 多 Agent 协同桌面工作台",
      "artifactName": "${productName}-${version}.${ext}",
      "mimeTypes": [
        "x-scheme-handler/agenthub"
      ]
    },
    "publish": [
      {
        "provider": "github",
        "owner": "XiYue-FireFly",
        "repo": "AgentHub"
      }
    ],
    "compression": "normal",
    "asar": true,
    "afterPack": null
  },
  "homepage": "https://agenthub.dev",
  "bugs": "https://github.com/XiYue-FireFly/AgentHub/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/XiYue-FireFly/AgentHub.git"
  }
}
