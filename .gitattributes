# AgentHub .gitattributes
# Force LF line endings for text files to avoid CRLF warnings in CI

*.ts text eol=lf
*.tsx text eol=lf
*.css text eol=lf
*.html text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf

# Binary files
*.png binary
*.jpg binary
*.ico binary
*.exe binary
*.dll binary
*.node binary
